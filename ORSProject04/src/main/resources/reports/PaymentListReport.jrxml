<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports
              http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="PaymentListReport"
              pageWidth="842" pageHeight="595"
              orientation="Landscape"
              columnWidth="782"
              leftMargin="30" rightMargin="30"
              topMargin="20" bottomMargin="20">

    <field name="id"            class="java.lang.Long"/>
    <field name="upi"           class="java.lang.String"/>
    <field name="card"          class="java.lang.String"/>
    <field name="netBanking"    class="java.lang.String"/>
    <field name="wallet"        class="java.lang.String"/>
    <field name="paymentStatus" class="java.lang.String"/>

    <title>
        <band height="55">
            <rectangle>
                <reportElement x="0" y="0" width="782" height="46" backcolor="#1565C0" forecolor="#1565C0"/>
                <graphicElement><pen lineWidth="0.0"/></graphicElement>
            </rectangle>
            <staticText>
                <reportElement x="0" y="4" width="782" height="38" forecolor="#FFFFFF"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="16" isBold="true"/>
                </textElement>
                <text><![CDATA[Payment List Report]]></text>
            </staticText>
        </band>
    </title>

    <pageHeader>
        <band height="18">
            <staticText>
                <reportElement x="0" y="0" width="391" height="18" forecolor="#666666"/>
                <textElement verticalAlignment="Middle"><font size="8"/></textElement>
                <text><![CDATA[Online Result System]]></text>
            </staticText>
            <textField pattern="dd-MM-yyyy HH:mm">
                <reportElement x="391" y="0" width="391" height="18" forecolor="#666666"/>
                <textElement textAlignment="Right" verticalAlignment="Middle"><font size="8"/></textElement>
                <textFieldExpression><![CDATA[new java.util.Date()]]></textFieldExpression>
            </textField>
        </band>
    </pageHeader>

    <columnHeader>
        <band height="26">
            <rectangle>
                <reportElement x="0" y="0" width="782" height="26" backcolor="#0D2137" forecolor="#0D2137"/>
                <graphicElement><pen lineWidth="0.0"/></graphicElement>
            </rectangle>
            <staticText>
                <reportElement x="0" y="0" width="25" height="26" forecolor="#FFFFFF"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font size="8" isBold="true"/></textElement>
                <text><![CDATA[#]]></text>
            </staticText>
            <staticText>
                <reportElement x="25" y="0" width="60" height="26" forecolor="#FFFFFF"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font size="8" isBold="true"/></textElement>
                <text><![CDATA[ID]]></text>
            </staticText>
            <staticText>
                <reportElement x="85" y="0" width="140" height="26" forecolor="#FFFFFF"/>
                <textElement verticalAlignment="Middle"><font size="8" isBold="true"/></textElement>
                <text><![CDATA[UPI]]></text>
            </staticText>
            <staticText>
                <reportElement x="225" y="0" width="140" height="26" forecolor="#FFFFFF"/>
                <textElement verticalAlignment="Middle"><font size="8" isBold="true"/></textElement>
                <text><![CDATA[Card]]></text>
            </staticText>
            <staticText>
                <reportElement x="365" y="0" width="140" height="26" forecolor="#FFFFFF"/>
                <textElement verticalAlignment="Middle"><font size="8" isBold="true"/></textElement>
                <text><![CDATA[Net Banking]]></text>
            </staticText>
            <staticText>
                <reportElement x="505" y="0" width="140" height="26" forecolor="#FFFFFF"/>
                <textElement verticalAlignment="Middle"><font size="8" isBold="true"/></textElement>
                <text><![CDATA[Wallet]]></text>
            </staticText>
            <staticText>
                <reportElement x="645" y="0" width="137" height="26" forecolor="#FFFFFF"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font size="8" isBold="true"/></textElement>
                <text><![CDATA[Payment Status]]></text>
            </staticText>
        </band>
    </columnHeader>

    <detail>
        <band height="22">
            <rectangle>
                <reportElement x="0" y="0" width="782" height="22" backcolor="#EEF2F7">
                    <printWhenExpression><![CDATA[$V{REPORT_COUNT} % 2 == 0]]></printWhenExpression>
                </reportElement>
                <graphicElement><pen lineWidth="0.0"/></graphicElement>
            </rectangle>
            <textField>
                <reportElement x="0" y="0" width="25" height="22" forecolor="#888888"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font size="8"/></textElement>
                <textFieldExpression><![CDATA[$V{REPORT_COUNT}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="25" y="0" width="60" height="22" forecolor="#888888"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font size="8"/></textElement>
                <textFieldExpression><![CDATA[$F{id}]]></textFieldExpression>
            </textField>
            <textField isBlankWhenNull="true">
                <reportElement x="85" y="0" width="140" height="22" forecolor="#1565C0"/>
                <textElement verticalAlignment="Middle"><font size="8" isBold="true"/></textElement>
                <textFieldExpression><![CDATA[$F{upi}]]></textFieldExpression>
            </textField>
            <textField isBlankWhenNull="true">
                <reportElement x="225" y="0" width="140" height="22"/>
                <textElement verticalAlignment="Middle"><font size="8"/></textElement>
                <textFieldExpression><![CDATA[$F{card}]]></textFieldExpression>
            </textField>
            <textField isBlankWhenNull="true">
                <reportElement x="365" y="0" width="140" height="22"/>
                <textElement verticalAlignment="Middle"><font size="8"/></textElement>
                <textFieldExpression><![CDATA[$F{netBanking}]]></textFieldExpression>
            </textField>
            <textField isBlankWhenNull="true">
                <reportElement x="505" y="0" width="140" height="22"/>
                <textElement verticalAlignment="Middle"><font size="8"/></textElement>
                <textFieldExpression><![CDATA[$F{wallet}]]></textFieldExpression>
            </textField>
            <textField isBlankWhenNull="true">
                <reportElement x="645" y="0" width="137" height="22" forecolor="#2E7D32"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font size="8" isBold="true"/></textElement>
                <textFieldExpression><![CDATA[$F{paymentStatus}]]></textFieldExpression>
            </textField>
        </band>
    </detail>

    <pageFooter>
        <band height="20">
            <line>
                <reportElement x="0" y="0" width="782" height="1" forecolor="#CCCCCC"/>
            </line>
            <staticText>
                <reportElement x="0" y="3" width="391" height="16" forecolor="#888888"/>
                <textElement><font size="8"/></textElement>
                <text><![CDATA[Online Result System - Payment List Report]]></text>
            </staticText>
            <textField>
                <reportElement x="391" y="3" width="391" height="16" forecolor="#888888"/>
                <textElement textAlignment="Right"><font size="8"/></textElement>
                <textFieldExpression><![CDATA["Page " + $V{PAGE_NUMBER}]]></textFieldExpression>
            </textField>
        </band>
    </pageFooter>

    <summary>
        <band height="30">
            <line>
                <reportElement x="0" y="4" width="782" height="1" forecolor="#CCCCCC"/>
            </line>
            <textField>
                <reportElement x="0" y="10" width="400" height="18" forecolor="#1565C0"/>
                <textElement><font size="9" isBold="true"/></textElement>
                <textFieldExpression><![CDATA["Total Payments: " + $V{REPORT_COUNT}]]></textFieldExpression>
            </textField>
        </band>
    </summary>

</jasperReport>
