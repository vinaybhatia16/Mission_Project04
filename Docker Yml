services:
  mysql:
    image: mysql:8.0
    container_name: ORSProject4-mysql
    environment:
      MYSQL_ROOT_PASSWORD: root
      MYSQL_DATABASE: p04
    ports:
      - "3308:3306"
    networks:
      - mynetwork
    volumes:
      - ./mysql-data:/var/lib/mysql

  webapp:
    build:
      context: .
    container_name: ORSProject4-webapp
    ports:
      - "8080:8080"
    networks:
      - mynetwork
    depends_on:
      - mysql
    environment:
      - JAVA_TOOL_OPTIONS=-Denv=docker  #  Important for JDBCDataSource
      - DATABASE_URL=jdbc:mysql://mysql:3306/p04

networks:
  mynetwork:
    driver: bridge
